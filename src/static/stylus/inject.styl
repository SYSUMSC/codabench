@import "src/static/stylus/components.styl"
.ui.image>img, .ui.segment, .ui.message, .ui.submission-container, .submission-form, .ui.dropdown.selection
	@extends.round-md

.ui.button
	@extends .btn-scale-xs
	@extends.round-md
.ui input
	@extends.round-md
.ui.form
	// @extends .round-md
	>div.field
		>div.ui.input
			@extends.round-md
			// >input
			// 	@extends.round-md
		>select
			@extends.round-md
			padding-right: 20px
			// >option
			// 	@extends.round-md
			// 	padding: 0.5rem
			// 	border: none
			// 	background: rgba(255, 255, 255, 0.85)
			// 	backdrop-filter: blur(10px)
	&.signup
		a
			color: var(--color-primary)!important
		input:focus
			border-color: var(--color-primary)!important
	&.login
		a
			color: var(--color-primary-purple)!important
		input:focus
			border-color: var(--color-primary-purple)!important

.ui.menu.tabular
	@extends.round-md
	border: none !important
	padding: 1rem 0.5rem!important
	margin: 0.5rem !important
	>div.item.active
		// !通过更匹配的选择器进一步提高优先级
		@extends.round-md
		@extends.btn-scale-sm
		@extends.transition-all
		// flex: 1
		&.active
			@extends.round-md
			background: var(--color-primary)!important
			color: white!important
table.ui.table
	@extends.round-md
	// overflow: hidden
	>thead>tr>th
		@extends.round-sm
		// @extends.transition-all
		// &:hover
		// 	// @extends.round-sm
		// 	transform: scale(1.02)
		// 	// background: var(--color-primary)!important
		// 	// color: white!important
.tile-wrapper
	@extends.round-md
	@extends.btn-scale-xs
	@extends.transition-all
	&:hover
		@extends.round-md
		// background: var(--color-primary)!important
	div.comp-stats
		@extends.round-md
		@extends.bg-primary
.ui.tab
	@extends.round-md
	margin-left: 0 !important
	margin-right: 0 !important
.ui.comp-tabs>.ui.tab
	min-height: 100vh
.ui.accordion
	.ui.title
		@extends.round-md
	.ui.content
		@extends.round-md
	@extends.round-md