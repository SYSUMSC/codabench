.ui.search .prompt
    // Value from semantic default input
    border-radius .28571429rem

#competition-search
    // Value from semantic default input
    border-radius 500rem



.result .content
    text-align left

.competition-search-parent
    height 3rem
    margin-left: 0.5rem
    color white
    background rgba(255, 255, 255, 0.5)
    border 2px solid #DDD
    border-radius: 50rem
    transition all 0.3s ease-in-out
    #competition-search
        width 10em
        height 100%
        padding 1rem
        border:  none
        border-radius: 50rem
        outline none
        background: transparent
        transition width 0.3s ease-in-out
        &:focus
            width 25em
            color: black
            background rgb(255, 255, 255)
    &:hover
    &:focus
        color black
        background rgb(255, 255, 255)
        #competition-search
            width 25em
    i
        margin: 0 0.6rem 0 0.4rem
